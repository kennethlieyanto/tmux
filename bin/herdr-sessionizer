#!/usr/bin/env bash
set -euo pipefail

NEW_WORKSPACE=false
if [[ "${1:-}" == "--new-workspace" ]]; then
    NEW_WORKSPACE=true
    shift
fi

if $NEW_WORKSPACE; then
    SESSION_NAME=$(herdr session list 2>/dev/null | awk '/running/{print $1; exit}')
    if [[ -z "$SESSION_NAME" ]]; then
        echo "No running herdr session found" >&2
        exit 1
    fi
    PROJECT_DIR="${1:-$PWD}"
else
    if [[ -n "${TMUX:-}" ]]; then
        SESSION_NAME=$(tmux display-message -p '#S')
        PROJECT_DIR=$(tmux display-message -p '#{pane_start_path}')
    else
        PROJECT_DIR="${1:-$PWD}"
        SESSION_NAME=$(basename "$PROJECT_DIR" | tr . _)
    fi
fi

herdr --session "$SESSION_NAME" server &>/dev/null &

for i in $(seq 1 10); do
    if herdr --session "$SESSION_NAME" workspace list &>/dev/null; then
        break
    fi
    sleep 1
done

WS_JSON=$(herdr --session "$SESSION_NAME" workspace create --cwd "$PROJECT_DIR" --focus)
WS_ID=$(echo "$WS_JSON" | jq -r '.result.workspace.workspace_id')
TAB1_ID=$(echo "$WS_JSON" | jq -r '.result.tab.tab_id')
PANE1_ID=$(echo "$WS_JSON" | jq -r '.result.root_pane.pane_id')

herdr --session "$SESSION_NAME" tab rename "$TAB1_ID" "opencode"
herdr --session "$SESSION_NAME" pane run "$PANE1_ID" "opencode"

TAB2_JSON=$(herdr --session "$SESSION_NAME" tab create --workspace "$WS_ID" --cwd "$PROJECT_DIR" --label "nvim")
PANE2_ID=$(echo "$TAB2_JSON" | jq -r '.result.root_pane.pane_id')
herdr --session "$SESSION_NAME" pane run "$PANE2_ID" "nvim"

TAB3_JSON=$(herdr --session "$SESSION_NAME" tab create --workspace "$WS_ID" --cwd "$PROJECT_DIR" --label "lazygit")
PANE3_ID=$(echo "$TAB3_JSON" | jq -r '.result.root_pane.pane_id')
herdr --session "$SESSION_NAME" pane run "$PANE3_ID" "lazygit"

if ! $NEW_WORKSPACE; then
    exec herdr --session "$SESSION_NAME"
fi
